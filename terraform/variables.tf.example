# Example Terraform variables for dev environment
# TODO: customize these values before running terraform apply.

aws_region = "us-east-1"
environment = "dev"

vpc_cidr = "10.0.0.0/16"

public_subnets = [
  "10.0.1.0/24",
  "10.0.2.0/24",
  "10.0.3.0/24",
]

private_subnets = [
  "10.0.10.0/24",
  "10.0.11.0/24",
  "10.0.12.0/24",
]

availability_zones = [
  "us-east-1a",
  "us-east-1b",
  "us-east-1c",
]

retention_days = 30

enable_ecs = false
enable_ec2_agent = false
enable_example_ecs_task = false

ecs_firelens_log_group_retention = 1

transition_to_ia_days = 30
transition_to_glacier_days = 90
expiration_days = 365
